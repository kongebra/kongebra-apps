---
import type { MarkdownHeading } from "astro";

interface Props {
  headings: MarkdownHeading[];
}
// Only h2/h3 - deeper nesting makes a noisy TOC.
const toc = Astro.props.headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{
  toc.length > 0 && (
    <nav class="toc" aria-label="Table of contents">
      <p class="toc-title mono">On this page</p>
      <ul>
        {toc.map((h) => (
          <li class:list={[{ sub: h.depth === 3 }]}>
            <a href={`#${h.slug}`}>{h.text}</a>
          </li>
        ))}
      </ul>
    </nav>
  )
}

<style>
  .toc { border-left: 1px solid var(--c-border); padding-left: 1rem; }
  .toc-title { margin: 0 0 0.6rem; text-transform: uppercase; letter-spacing: 0.08em; }
  ul { list-style: none; margin: 0; padding: 0; }
  li { margin: 0.35rem 0; }
  li.sub { padding-left: 0.9rem; }
  a {
    font-family: var(--font-display);
    font-size: 0.85rem;
    color: var(--c-muted);
    text-decoration: none;
    line-height: 1.35;
    display: block;
  }
  a:hover { color: var(--c-accent); }
</style>
