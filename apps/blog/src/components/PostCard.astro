---
import FormattedDate from "./FormattedDate.astro";

interface Props {
  slug: string;
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  minutes: number;
  /** Stagger index for the page-load reveal. */
  index?: number;
}
const { slug, title, description, pubDate, tags, minutes, index = 0 } = Astro.props;
---

<article class="card" style={`--i:${index}`}>
  <div class="meta mono">
    <FormattedDate date={pubDate} />
    <span aria-hidden="true">·</span>
    <span>{minutes} min read</span>
  </div>
  <h2><a href={`/posts/${slug}/`}>{title}</a></h2>
  <p class="desc">{description}</p>
  <div class="foot">
    <ul class="tags mono">
      {tags.map((t) => <li><a href={`/tags/${t}/`}>#{t}</a></li>)}
    </ul>
    <a class="more" href={`/posts/${slug}/`}>Read article <span aria-hidden="true">→</span></a>
  </div>
</article>

<style>
  .card {
    padding: 2rem 0;
    border-bottom: 1px solid var(--c-border);
    animation: rise 0.5s ease both;
    animation-delay: calc(var(--i) * 70ms);
  }
  .meta { display: flex; align-items: center; gap: 0.5rem; }
  h2 {
    margin: 0.55rem 0 0.4rem;
    font-size: 1.5rem;
  }
  h2 a { text-decoration: none; }
  h2 a:hover { color: var(--c-accent); }
  .desc { margin: 0; color: var(--c-muted); }
  .foot {
    margin-top: 0.9rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .tags { list-style: none; display: flex; gap: 0.7rem; padding: 0; margin: 0; }
  .tags a { text-decoration: none; }
  .tags a:hover { color: var(--c-accent); }
  .more {
    font-family: var(--font-display);
    font-size: 0.9rem;
    color: var(--c-accent);
    text-decoration: none;
    white-space: nowrap;
  }
  .more:hover span { margin-left: 0.2rem; }
  .more span { transition: margin-left 0.15s; }
  @keyframes rise {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: none; }
  }
</style>
