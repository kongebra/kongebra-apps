---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { getPosts } from "../../lib/posts.ts";

export async function getStaticPaths() {
  const posts = await getPosts();
  const tags = [...new Set(posts.flatMap((p) => p.data.tags))];
  return tags.map((tag) => ({
    params: { tag },
    props: { tag, posts: posts.filter((p) => p.data.tags.includes(tag)) },
  }));
}

const { tag, posts } = Astro.props;
---

<BaseLayout title={`#${tag}`} description={`Posts tagged #${tag}.`}>
  <div class="container">
    <p class="mono kicker">Tag</p>
    <h1>#{tag}</h1>
    <p class="lede">{posts.length} post{posts.length === 1 ? "" : "s"}.</p>
    {posts.map((post, i) => (
      <PostCard
        slug={post.id}
        title={post.data.title}
        description={post.data.description}
        pubDate={post.data.pubDate}
        tags={post.data.tags}
        minutes={post.minutes}
        index={i}
      />
    ))}
  </div>
</BaseLayout>

<style>
  .kicker { text-transform: uppercase; letter-spacing: 0.1em; margin: 0; }
  h1 { font-size: clamp(2rem, 5vw, 2.8rem); margin: 0.3rem 0 0.4rem; }
  .lede { color: var(--c-muted); margin: 0 0 1rem; }
</style>
