# build stage: full toolchain
FROM node:22-slim AS build
WORKDIR /src
# node:22 ships npm 10, but package-lock.json is generated by npm 11 (dev + CI use
# node 24 / npm 11). npm 10's `npm ci` rejects an npm-11 lockfile as out-of-sync
# ("Missing <transitive> from lock file"). Pin npm 11 so the tooling matches the lock.
RUN npm install -g npm@11.17.0
COPY package.json package-lock.json ./
RUN npm ci
COPY . .
ARG VERSION=dev
ENV VITE_APP_VERSION=${VERSION}
RUN npm run build

# runtime: only the Nitro .output on a slim base
FROM node:22-slim AS runtime
WORKDIR /app
ENV NODE_ENV=production
# saga-api base URL for SSR; overridden in k8s to the in-cluster service.
ENV SAGA_API_URL=http://saga-api:8080
COPY --from=build /src/.output ./.output
USER 65532:65532
EXPOSE 3000
ENTRYPOINT ["node", ".output/server/index.mjs"]
