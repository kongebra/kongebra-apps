# TronderLeikan admin - miljøvariabler (server-side). Ingenting hardkodes (SPEC §5).
# Lokalt settes disse av Aspire AppHost; i cluster av gitops-manifestet.
# Appen serveres under /admin (SPEC §10); healthz-proben er GET /admin/healthz.

# BFF -> platform-tjenesten (intern URL; inkluder ikke /api-prefikset - rutene
# definerer det selv). Admin-planet snakker kun med platform.
PLATFORM_URL=http://localhost:8081

# Zitadel OIDC (Authorization Code + PKCE, public client). EGEN Zitadel-app for
# admin, separat fra web (SPEC §10) - derfor egen AUTH_CLIENT_ID.
AUTH_ISSUER=http://localhost:8300
AUTH_CLIENT_ID=tronderleikan-admin
# Valgfritt: audience for API-token (Zitadel prosjekt-scope). Verifiseres i 1.6.
AUTH_AUDIENCE=
# Valgfritt: overstyr scopes. offline_access trengs for refresh-token.
# AUTH_SCOPES=openid profile email offline_access
# Valgfritt: eksplisitt base-URL for redirect_uri (utledes ellers fra requesten).
# redirect_uri blir <ADMIN_BASE_URL>/admin/auth/callback.
# ADMIN_BASE_URL=https://leikan.newb.no

# Forsegling av session-cookien (iron). Minst 32 tegn. Bruk en tilfeldig verdi.
# Egen verdi fra web sin: admin- og web-cookien deler origin men ulikt navn.
SESSION_SECRET=change-me-to-a-random-32+-char-secret
